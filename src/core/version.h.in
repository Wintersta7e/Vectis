#pragma once

namespace vectis::core {

/// Single source of truth for the Vectis version string. Generated by
/// CMake's `configure_file` from `project(... VERSION ...)` — bump the
/// version in the root `CMakeLists.txt`, never here. `const char*` (not
/// `std::string_view`) so it converts cleanly at `nlohmann::json` and
/// `std::string` boundaries without an explicit wrap.
inline constexpr const char* k_vectis_version = "@PROJECT_VERSION@";

} // namespace vectis::core
